# Glamer UAT — environment configuration
# Copy to `.env` and fill in. NEVER commit `.env` (it's gitignored).

# --- Base URLs (the deployed UAT environment) ---
API_BASE_URL=https://api.uat.glamer.example
WEB_BASE_URL=https://app.uat.glamer.example

# --- Test accounts (ring-fenced UAT accounts, never real users) ---
TEST_CLIENT_EMAIL=uat.client@glamer.example
TEST_CLIENT_PASSWORD=change-me
TEST_STYLIST_EMAIL=uat.stylist@glamer.example
TEST_STYLIST_PASSWORD=change-me

# --- Seed / reset ---
# How the suite resets UAT to a known state. [CONFIRM the real mechanism.]
# e.g. a protected seed endpoint + token, or a script.
SEED_URL=https://api.uat.glamer.example/internal/seed
SEED_TOKEN=change-me

# --- Payments (test mode) ---
# A card token/number that always declines, for unhappy-path tests (C-4 / A-6). [CONFIRM]
TEST_CARD_DECLINE=4000000000000002
